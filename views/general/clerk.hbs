<div class="page-header">
  <h1>Add Meal Kit</h1>
  <p>Create a new meal kit for your customers.</p>
</div>

{{#if user.clerk}}
<section class="form-container">
  <div class="form-card">
    {{#each errors}}
      <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{this}}</p>
    {{/each}}
    {{#each result}}
      <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{this}}</p>
    {{/each}}

    <form action="/load-data/meal-kits" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label for="title">Meal Title</label>
        <input type="text" id="title" name="title" placeholder="e.g. Butter Chicken Thali">
      </div>

      <div class="form-group">
        <label for="wIncluded">What's Included</label>
        <input type="text" id="wIncluded" name="wIncluded" placeholder="e.g. Naan, Rice, Raita">
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="4" placeholder="Describe the flavors and origins..."></textarea>
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <select name="category" id="category">
          <option value="classic">Classic Meal</option>
          <option value="starter">Starter</option>
        </select>
      </div>

      <div class="form-group">
        <label for="price">Price (CAD)</label>
        <input type="text" id="price" name="price" placeholder="24.99">
      </div>

      <div class="form-group">
        <label for="cookingTime">Cooking Time (minutes)</label>
        <input type="text" id="cookingTime" name="cookingTime" placeholder="35">
      </div>

      <div class="form-group">
        <label for="servings">Servings</label>
        <input type="text" id="servings" name="servings" placeholder="2">
      </div>

      <div class="form-group">
        <label for="calories">Calories Per Serving</label>
        <input type="text" id="calories" name="calories" placeholder="680">
      </div>

      <div class="form-group">
        <label>Top Meal?</label>
        <div class="radio-group">
          <label><input type="radio" name="topMeal" value="true"> Yes</label>
          <label><input type="radio" name="topMeal" value="false" checked> No</label>
        </div>
      </div>

      <div class="form-group">
        <label>Upload Photo</label>
        <input type="file" name="photo" accept="image/*" id="photo">
      </div>

      <button type="submit" class="btn btn-primary btn-submit">Add Meal Kit</button>
    </form>
  </div>
</section>
{{else}}
<div class="section" style="text-align:center;">
  <h2 style="color:#ff6b6b; font-size:2rem;"><i class="fas fa-lock"></i> Access Denied</h2>
  <p>Only authorized clerks can access this page.</p>
</div>
{{/if}}