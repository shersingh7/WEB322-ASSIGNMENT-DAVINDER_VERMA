<div class="auth-page">
  <div class="auth-card">
    <h2>Create Account</h2>
    <p class="subtitle">Join Desi Khana and start eating better</p>

    <form action="/registration" method="POST">
      <div class="form-group">
        <label for="fname">First Name</label>
        <input type="text" id="fname" name="fname" placeholder="Davinder" value="{{values.fname}}">
        {{#if validationResults.fname}}
          <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{validationResults.fname}}</p>
        {{/if}}
      </div>

      <div class="form-group">
        <label for="lname">Last Name</label>
        <input type="text" id="lname" name="lname" placeholder="Verma" value="{{values.lname}}">
        {{#if validationResults.lname}}
          <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{validationResults.lname}}</p>
        {{/if}}
      </div>

      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" value="{{values.email}}">
        {{#if validationResults.email}}
          <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{validationResults.email}}</p>
        {{/if}}
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••">
        {{#if validationResults.password}}
          <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{validationResults.password}}</p>
        {{/if}}
      </div>

      <button type="submit" class="btn-submit">Create Account</button>
    </form>

    <p class="auth-footer">Already have an account? <a href="/login">Sign in</a></p>
  </div>
</div>