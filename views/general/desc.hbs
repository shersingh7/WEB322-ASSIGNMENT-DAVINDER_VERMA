<div class="page-header">
  <h1>Meal Details</h1>
</div>

<section class="section">
  <div class="meals-grid" style="max-width:600px; margin:0 auto;">
    {{#each kit}}
    <div class="meal-card reveal" style="text-align:center;">
      <div class="meal-image" style="height:300px;">
        <img src="/{{photo}}" alt="{{title}}">
      </div>
      <div class="meal-info" style="padding:36px;">
        <h2 style="font-size:1.8rem; margin-bottom:8px;">{{title}}</h2>
        <p style="color:var(--text-light); margin-bottom:16px;">{{wIncluded}}</p>
        <p style="color:var(--text-light); line-height:1.7; margin-bottom:20px;">{{description}}</p>
        <div class="meal-meta" style="justify-content:center;">
          <span><i class="far fa-clock"></i> {{cookingTime}} min</span>
          <span><i class="fas fa-fire"></i> {{calories}} cal</span>
          <span><i class="fas fa-user-friends"></i> {{servings}}</span>
        </div>
        <div class="meal-price" style="font-size:2rem; margin:20px 0;">${{price}}</div>
        <form method="POST" action="/load-data/addToCart/{{title}}">
          <button type="submit" class="btn btn-primary" style="width:100%; padding:16px; font-size:1.1rem;">
            <i class="fas fa-cart-plus"></i> Add to Cart
          </button>
        </form>
      </div>
    </div>
    {{/each}}
  </div>
</section>