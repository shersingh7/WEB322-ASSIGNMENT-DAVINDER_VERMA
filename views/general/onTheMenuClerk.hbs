<div class="page-header">
  <h1>Clerk Dashboard</h1>
  <p>Update meal kits and manage your menu.</p>
</div>

<section class="section">
  <h2 class="section-title reveal" style="text-align:left;">
    <span style="font-size:1.8rem; font-weight:900; color:var(--dark);">Classic Meals</span>
  </h2>
  <div class="clerk-grid">
    {{#each result}}
      <p style="color:#ff6b6b; font-weight:700;">{{this}}</p>
    {{/each}}
    {{#each classic}}
    <div class="clerk-card reveal">
      <img src="{{photo}}" alt="{{title}}">
      <form action="/load-data/update" method="POST">
        <input type="hidden" name="id" value="{{_id}}">
        <div class="form-group">
          <label>Title</label>
          <input type="text" name="title" value="{{title}}">
        </div>
        <div class="form-group">
          <label>Included</label>
          <input type="text" name="wIncluded" value="{{wIncluded}}">
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="2">{{description}}</textarea>
        </div>
        <div class="form-group">
          <label>Price</label>
          <input type="text" name="price" value="{{price}}">
        </div>
        <div class="form-group">
          <label>Cooking Time</label>
          <input type="text" name="cookingTime" value="{{cookingTime}}">
        </div>
        <div class="form-group">
          <label>Servings</label>
          <input type="text" name="servings" value="{{servings}}">
        </div>
        <div class="form-group">
          <label>Calories</label>
          <input type="text" name="calories" value="{{calories}}">
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Update Meal</button>
      </form>
    </div>
    {{/each}}
  </div>

  <h2 class="section-title reveal" style="text-align:left; margin-top:60px;">
    <span style="font-size:1.8rem; font-weight:900; color:var(--dark);">Starters</span>
  </h2>
  <div class="clerk-grid">
    {{#each result}}
      <p style="color:#ff6b6b; font-weight:700;">{{this}}</p>
    {{/each}}
    {{#each starter}}
    <div class="clerk-card reveal">
      <img src="{{photo}}" alt="{{title}}">
      <form action="/load-data/update" method="POST">
        <input type="hidden" name="id" value="{{_id}}">
        <div class="form-group">
          <label>Title</label>
          <input type="text" name="title" value="{{title}}">
        </div>
        <div class="form-group">
          <label>Included</label>
          <input type="text" name="wIncluded" value="{{wIncluded}}">
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="2">{{description}}</textarea>
        </div>
        <div class="form-group">
          <label>Price</label>
          <input type="text" name="price" value="{{price}}">
        </div>
        <div class="form-group">
          <label>Cooking Time</label>
          <input type="text" name="cookingTime" value="{{cookingTime}}">
        </div>
        <div class="form-group">
          <label>Servings</label>
          <input type="text" name="servings" value="{{servings}}">
        </div>
        <div class="form-group">
          <label>Calories</label>
          <input type="text" name="calories" value="{{calories}}">
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Update Meal</button>
      </form>
    </div>
    {{/each}}
  </div>
</section>