<div class="auth-page">
  <div class="auth-card">
    <h2>Welcome Back</h2>
    <p class="subtitle">Sign in to your Desi Khana account</p>

    {{#each errors}}
      <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{this}}</p>
    {{/each}}

    <form action="/login" method="POST">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" value="{{values.email}}">
        {{#if validationResults.email}}
          <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{validationResults.email}}</p>
        {{/if}}
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••">
        {{#if validationResults.password}}
          <p class="form-error"><i class="fas fa-circle-exclamation"></i> {{validationResults.password}}</p>
        {{/if}}
      </div>

      <div class="form-group">
        <label>Account Type</label>
        <div class="radio-group">
          <label><input type="radio" name="type" value="customer" checked> Customer</label>
          <label><input type="radio" name="type" value="clerk"> Data Clerk</label>
        </div>
      </div>

      <button type="submit" class="btn-submit">Sign In</button>
    </form>

    <p class="auth-footer">Don't have an account? <a href="/registration">Create one</a></p>
  </div>
</div>